{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Pet",
  "version": "0.1.7",
  "identifier": "com.claudepet.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "pet",
        "title": "Claude Pet",
        "width": 150,
        "height": 150,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "center": false,
        "x": 1100,
        "y": 600
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns"
    ],
    "category": "Utility",
    "shortDescription": "Claude Code desktop pet",
    "longDescription": "A pixel desktop pet that shows Claude Code's live working status and alerts you when Claude needs your attention.",
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
